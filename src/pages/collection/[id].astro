---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { id: 'salon' } },
    { params: { id: 'comedor' } },
    { params: { id: 'iluminacion' } },
  ];
}

const { id } = Astro.params;

// Collections definitions
const collections = {
  'salon': {
    name: "Salón & Sofás",
    description: "Espacios de relajación y confort. Descubre nuestra gama de sofás modulares y conjuntos de banquetas tapizados artesanalmente en lino, terciopelo o cuero premium.",
    bannerImage: "https://images.unsplash.com/photo-1555041469-a586c61ea9bc?auto=format&fit=crop&w=1200&q=80"
  },
  'comedor': {
    name: "Mesas & Comedor",
    description: "Reuniones en torno al diseño. Tableros de roble macizo y siluetas escandinavas limpias que combinan funcionalidad diaria con una estética atemporal.",
    bannerImage: "https://images.unsplash.com/photo-1615066390971-03e4e1c36ddf?auto=format&fit=crop&w=1200&q=80"
  },
  'iluminacion': {
    name: "Lámparas & Decoración",
    description: "El arte de la atmósfera. Iluminación de estudio y objetos decorativos diseñados para aportar calidez visual, texturas ricas y serenidad.",
    bannerImage: "https://images.unsplash.com/photo-1507473885765-e6ed057f782c?auto=format&fit=crop&w=1200&q=80"
  }
};

// Full catalog products list
const allProducts = [
  {
    id: 'nordic-sofa',
    name: 'Sofá Modular Nørde',
    category: 'Sofás',
    collectionId: 'salon',
    price: 'S/ 4,299',
    image: '/myo/images/sofa_base.png',
    tag: 'Personalizable'
  },
  {
    id: 'ottoman-set',
    name: 'Juego de Banquetes Bergen',
    category: 'Juegos',
    collectionId: 'salon',
    price: 'S/ 3,199',
    image: '/myo/images/benches_base.png',
    tag: 'Personalizable'
  }
];

const collection = collections[id as keyof typeof collections] || collections['salon'];
const filteredProducts = allProducts.filter(p => p.collectionId === id);
---

<Layout 
  title={`Colección ${collection.name}`} 
  description={collection.description}
>
  {/* Collection Banner Header */}
  <section class="relative bg-[#f5f2eb] py-16 md:py-20 border-b border-[#ecece8] overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      {/* Text Info */}
      <div class="lg:col-span-6 space-y-5">
        <nav class="flex gap-2 text-xs font-bold text-[#cfa163] uppercase tracking-wider mb-2">
          <a href="/myo" class="hover:underline">Inicio</a>
          <span>/</span>
          <span>Colección</span>
        </nav>
        
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-[#1f2022]">
          {collection.name}
        </h1>
        <p class="text-sm md:text-base text-[#5c5c56] leading-relaxed max-w-xl">
          {collection.description}
        </p>
      </div>

      {/* Visual background element */}
      <div class="lg:col-span-6 h-64 md:h-80 rounded-2xl overflow-hidden shadow-lg border border-[#ecece8]">
        <img 
          src={collection.bannerImage} 
          alt={`Banner Colección ${collection.name}`} 
          class="w-full h-full object-cover"
        />
      </div>

    </div>
  </section>

  {/* Products Grid list */}
  <section class="py-16 md:py-24 max-w-7xl mx-auto px-6">
    <div class="flex items-center justify-between border-b border-[#ecece8] pb-4 mb-10">
      <span class="text-xs font-bold text-[#8b8b83] uppercase tracking-widest">
        {filteredProducts.length} {filteredProducts.length === 1 ? 'Producto' : 'Productos'} Encontrados
      </span>
    </div>

    {filteredProducts.length === 0 ? (
      <div class="text-center py-20 bg-white rounded-2xl border border-[#ecece8]">
        <p class="text-[#8b8b83] text-sm">No se encontraron productos en esta colección.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {filteredProducts.map((prod) => (
          <div class="group relative flex flex-col justify-between bg-white rounded-2xl border border-[#ecece8] p-5 shadow-sm hover:shadow-md transition-all duration-300">
            <div>
              <div class="relative w-full aspect-square rounded-xl overflow-hidden bg-[#fafaf9] mb-4 group shadow-sm border border-[#ecece8]/50">
                <img 
                  src={prod.image} 
                  alt={prod.name} 
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                {prod.tag && (
                  <span class="absolute top-3 left-3 bg-[#1f2022] text-white text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">
                    {prod.tag}
                  </span>
                )}
              </div>
              <div class="space-y-1">
                <span class="text-[10px] font-bold text-[#cfa163] uppercase tracking-wider">{prod.category}</span>
                <h3 class="text-base font-bold text-[#1f2022] tracking-tight group-hover:text-[#cfa163] transition-colors">
                  <a href={`/myo/product/${prod.id}`}>{prod.name}</a>
                </h3>
              </div>
            </div>
            
            <div class="flex items-center justify-between mt-4 pt-4 border-t border-[#ecece8]">
              <span class="text-sm font-bold text-[#1f2022]">{prod.price}</span>
              <a href={`/myo/product/${prod.id}`} class="text-xs font-bold text-[#1f2022] uppercase tracking-wider hover:text-[#cfa163] transition-colors">
                Ver Detalles &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>
